  "name": "Template",
  "image": "ghcr.io/jon77p/codespaces/images/default:latest@sha256:29cba1391b6c83da1e2251f9fc1f3cd50c454c7557a99ce3521f54cc29440f9a",

  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  // "forwardPorts": [],

  "postStartCommand": "task setup",

  "features": {
    "ghcr.io/devcontainers/features/aws-cli:1@sha256:1f93c8315b7a6d76982ebb2269f8b0d50413fc0f965c032edf4aee0caceb73ef": {
      "version": "latest"
    },
    // "ghcr.io/devcontainers/features/docker-from-docker:1": {
    //   "version": "latest"
    // },
    "ghcr.io/devcontainers/features/rust:1@sha256:f7afd923fd283db88ca961342ae65ea63a8c95bcf86e42c4c363f43bc4ba26a5": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/terraform:1@sha256:503d0888b3a43a32335e08cd4477f8c4629404ad83f6a36f0e0fee7f567c06c7": {
      "version": "latest"
    },
    "ghcr.io/jon77p/codespaces/features/tailscale:latest@sha256:b24f019db029c8630ab3d962f706b792c002e34e8baf2adcf8da3fdef339f850": {
      "version": "latest"
    },
    "ghcr.io/jon77p/codespaces/features/taskfile:latest@sha256:c896eb5bc841597ae291bd18cd719b8eb5cdff93c2852bf31a74d182f2593bef": {
      "version": "latest"
    }
  },

  // VSCode Editor Settings
  "settings": {
    "sync.autoDownload": true,
    "sync.autoUpload": true,
    "telemetry.enableTelemetry": false,
    "redhat.telemetry.enabled": false,
    "debug.javascript.autoAttachFilter": "smart",
    "git.autofetch": true,
    "git.autoStash": true,
    "git.branchProtection": ["main"],
    "files.associations": {
      "*.yml": "yaml"
    },
    "yaml.schemas": {
      "https://json.schemastore.org/taskfile.json": ".github/tasks/**/*.yml"
    },
    "git.confirmSync": true,
    "editor.inlineSuggest.enabled": true,
    "github.copilot.inlineSuggest.enable": true,
    "github.copilot.enable": {
      "*": true,
      "yaml": true,
      "plaintext": false,
      "markdown": false
    }
  }
}
